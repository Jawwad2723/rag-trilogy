      "id": 1,
      "title": "Request Rate & Status",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "editorMode": "code",
          "expr": "sum(rate(rag_requests_total[5m])) by (status, model)",
          "legendFormat": "{{model}} ({{status}})",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "id": 2,
      "title": "p50 / p95 / p99 Latency",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.50, sum(rate(rag_total_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50 Latency",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum(rate(rag_total_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95 Latency",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.99, sum(rate(rag_total_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99 Latency",
          "refId": "C"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "id": 3,
      "title": "Requests In Flight",
      "type": "gauge",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "editorMode": "code",
          "expr": "rag_requests_in_flight",
          "legendFormat": "Active Requests",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 4,
      "title": "Latency Breakdown by Stage (Average)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "editorMode": "code",
          "expr": "sum(rate(rag_retrieval_latency_seconds_sum[5m])) / sum(rate(rag_retrieval_latency_seconds_count[5m]))",
          "legendFormat": "Retrieval",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "editorMode": "code",
          "expr": "sum(rate(rag_reranking_latency_seconds_sum[5m])) / sum(rate(rag_reranking_latency_seconds_count[5m]))",
          "legendFormat": "Reranking",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "editorMode": "code",
          "expr": "sum(rate(rag_generation_latency_seconds_sum[5m])) / sum(rate(rag_generation_latency_seconds_count[5m]))",
          "legendFormat": "Generation",
          "refId": "C"
        }
      ]
    }
  ],
